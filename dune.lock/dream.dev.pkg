(version dev)

(build
 (all_platforms ((action (run dune build -p %{pkg-self:name} -j %{jobs})))))

(depends
 (all_platforms
  (base-unix
   bigarray-compat
   camlp-streams
   caqti
   caqti-lwt
   conf-libev
   cstruct
   digestif
   dream-httpaf
   dream-pure
   dune
   fmt
   graphql_parser
   graphql-lwt
   lambdasoup
   lwt
   lwt_ppx
   lwt_ssl
   logs
   magic-mime
   markup
   mirage-ptime
   mirage-crypto
   mirage-crypto-rng
   multipart_form
   multipart_form-lwt
   ocaml
   ptime
   ssl
   uri
   yojson)))

(source
 (fetch
  (url
   git+https://github.com/camlworks/dream#1fbb7fd440cff3cf6514d7f9aa0da73d21466611)))

(dev)
