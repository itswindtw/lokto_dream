(version dev)

(build
 (all_platforms ((action (run dune build -p %{pkg-self:name} -j %{jobs})))))

(depends
 (all_platforms
  (dream-pure
   dune
   gluten
   gluten-lwt-unix
   h2
   h2-lwt-unix
   httpun
   httpun-lwt-unix
   httpun-ws
   lwt
   lwt_ppx
   lwt_ssl
   ocaml
   ssl)))

(source
 (fetch
  (url
   git+https://github.com/camlworks/dream#1fbb7fd440cff3cf6514d7f9aa0da73d21466611)))

(dev)
